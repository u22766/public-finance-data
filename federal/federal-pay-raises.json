    "last_updated": "2026-03-12",
    "sources": [
      "https://www.opm.gov/policy-data-oversight/pay-leave/pay-systems/general-schedule/",
      "https://www.dfas.mil/militarymembers/payentitlements/Pay-Tables/",
      "Congressional Research Service: Federal Pay (RL34463)",
      "https://www.federalpay.org/gs/raise"
    ],
    "notes": [
      "GS raises include base adjustment plus locality pay changes. Amount shown is the overall average.",
      "Military raises are set by National Defense Authorization Act (NDAA) and apply to basic pay.",
      "Pay freeze years: 2011-2013 for GS (0% base, though some locality adjustments still applied).",
      "For FERS pension: high-3 uses highest 3 consecutive years of basic pay. Pay raise history helps project future high-3.",
      "For military retirement: Final Pay, High-3, or BRS depending on entry date. All use basic pay."
    ]
  },
