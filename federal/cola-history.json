{
  "metadata": {
    "title": "Historical COLA Data \u2014 Social Security, FERS, CSRS, and VA",
    "description": "Annual cost-of-living adjustment percentages for Social Security benefits, FERS annuities, CSRS annuities, and VA compensation/DIC. Covers 1975-2025 (51 years).",
    "version": "1.0",
    "last_updated": "2026-03-11",
    "source": "https://www.ssa.gov/oact/cola/colaseries.html",
    "notes": {
      "year_meaning": "The COLA year indicates when the adjustment was announced. 1975-1982 COLAs applied to June benefits. 1983+ COLAs apply to December benefits (paid in January of the following year). E.g., the 2025 COLA of 2.8% is paid with January 2026 benefits.",
      "social_security": "Based on CPI-W third-quarter comparison. Cannot be negative. Three zero-COLA years: 2009, 2010, 2015.",
      "csrs": "Civil Service Retirement System. Receives full SS COLA percentage with no cap.",
      "fers": "Federal Employees Retirement System (established 1987). COLA capped: if CPI \u2264 2%, FERS = CPI; if CPI 2-3%, FERS = 2%; if CPI > 3%, FERS = CPI minus 1 percentage point. FERS-RAE and FERS-FRAE follow the same COLA formula.",
      "va": "Veterans Affairs disability compensation and DIC. Typically matches Social Security COLA; enacted separately by Congress but has matched the SS percentage in modern practice.",
      "1999_note": "The 1999 COLA was originally 2.4% but was retroactively changed to 2.5% by P.L. 106-554."
    }
  },
  "cola_formula": {
    "fers": {
      "description": "FERS COLA is derived from the CPI increase (same basis as SS COLA) with a cap",
      "rules": [
        {
          "condition": "CPI increase \u2264 2.0%",
          "fers_cola": "equals CPI increase"
        },
        {
          "condition": "CPI increase 2.0% to 3.0%",
          "fers_cola": "2.0%"
        },
        {
          "condition": "CPI increase > 3.0%",
          "fers_cola": "CPI increase minus 1.0 percentage point"
        }
      ],
      "minimum": 0.0,
      "example": "If CPI increase is 5.9% (as in 2021), FERS COLA = 5.9% - 1.0% = 4.9%"
    }
  },
